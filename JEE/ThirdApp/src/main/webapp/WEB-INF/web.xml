  		<servlet-class>com.jee.DemoServlet</servlet-class>
  </servlet>
  
    <servlet-mapping>
  		<servlet-name>tsf</servlet-name>
  		<url-pattern>/TestServlet</url-pattern>
  </servlet-mapping>
  
  <servlet>
  		<servlet-name>tsf</servlet-name>
  		<servlet-class>com.jee.TestServlet</servlet-class>
  </servlet>
  
</web-app>